# node101-benchmark configuration
# Copy this file to .env and fill in the values

# ── Server ────────────────────────────────────────────
PORT=3001

# ── Email (optional) ──────────────────────────────────
# Leave SMTP_HOST empty to disable email sending.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password

MAIL_FROM=node101 Benchmark <you@gmail.com>
MAIL_TO=recipient@example.com
# Placeholders: {chain}, {date}
MAIL_SUBJECT=Benchmark Report: {chain} — {date}

# ── Queue ─────────────────────────────────────────────
# Cooldown between sequential tests (seconds). Default: 300
QUEUE_COOLDOWN_SECONDS=300
